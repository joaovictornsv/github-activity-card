# Required: GitHub username whose public events to fetch
GITHUB_USERNAME=your-username

# Single token shared by activity + stats crons (see README "GitHub token")
# Classic PAT scopes: gist, read:user, repo
# GITHUB_TOKEN=

# Optional overrides (defaults shown)
# OUTPUT_PATH=output/your-username-activity.gif
# SLIDE_DURATION_SEC=2.5
# CARD_WIDTH=415
# CARD_HEIGHT=124
# DEVICE_SCALE_FACTOR=2
# GIF_MAX_COLORS=256
# GIF_BAYER_SCALE=2

# --- Gist publish (optional for scheduler; required for npm run upload) ---
# Create a secret gist with a file named activity.gif, then paste its ID (hex from the URL).
# GIST_ID=
# GIST_FILENAME=activity.gif

# --- Activity summary PNG (optional; generated with npm run generate:activity-summary) ---
# ACTIVITY_SUMMARY_OUTPUT_PATH=output/your-username-activity-summary.png
# Publish to the same gist as activity.gif by default (falls back to GIST_ID).
# ACTIVITY_SUMMARY_GIST_ID=
# ACTIVITY_SUMMARY_GIST_FILENAME=activity-summary.png

# --- Stats card gist publish (optional for stats scheduler; required for npm run upload:stats) ---
# Create a secret gist with a file named stats.png, then paste its ID.
# STATS_GIST_ID=
# STATS_GIST_FILENAME=stats.png
# STATS_OUTPUT_PATH=output/your-username-stats.png

# --- Scheduler (npm run scheduler / npm run scheduler:stats) ---
# PORT=3000
# CRON_TZ=America/Sao_Paulo
# SCHEDULER_RUN_ON_START=1
