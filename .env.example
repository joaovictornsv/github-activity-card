# Required: GitHub username whose public events to fetch
GITHUB_USERNAME=your-username

# Optional: increases rate limit from 60/hr to 5000/hr (public endpoints only)
# GITHUB_TOKEN=

# Optional overrides (defaults shown)
# OUTPUT_PATH=output/your-username-activity.gif
# SLIDE_DURATION_SEC=2.5
# CARD_WIDTH=415
# CARD_HEIGHT=96
# DEVICE_SCALE_FACTOR=2
# GIF_MAX_COLORS=256
# GIF_BAYER_SCALE=2

# --- R2 upload (required for npm run upload / npm run scheduler) ---
# Cloudflare dashboard → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_OBJECT_KEY=github-activity-card/your-username-activity.gif
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# R2_CACHE_CONTROL=public, max-age=3600

# --- Gist mirror (optional; runs after R2 upload when GIST_ID is set) ---
# Create a secret gist with a file named activity.gif, then paste its ID (hex from the URL).
# PAT needs the gist scope (classic) or Gists read/write (fine-grained).
# GIST_ID=
# GIST_FILENAME=activity.gif

# --- Scheduler (npm run scheduler) ---
# PORT=3000
# CRON_TZ=America/Sao_Paulo
# SCHEDULER_RUN_ON_START=1
