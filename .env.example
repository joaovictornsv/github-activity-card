# Required: GitHub username whose public events to fetch
GITHUB_USERNAME=your-username

# Optional: increases rate limit from 60/hr to 5000/hr (public endpoints only)
# GITHUB_TOKEN=

# Optional overrides (defaults shown)
# OUTPUT_PATH=output/activity.gif
# SLIDE_DURATION_SEC=2.5
# CARD_WIDTH=415
# CARD_HEIGHT=96
