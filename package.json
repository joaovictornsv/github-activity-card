{
  "name": "github-activity-card",
  "version": "0.1.0",
  "description": "Daily-updated GIF slideshow of your last public GitHub activities",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "generate": "node src/index.js",
    "generate:stats": "node src/stats-index.js",
    "upload": "node src/upload.js",
    "upload:stats": "node src/upload-stats.js",
    "scheduler": "node src/scheduler.js",
    "scheduler:stats": "node src/stats-scheduler.js",
    "schedulers": "node src/schedulers.js",
    "check:token": "node src/check-token.js",
    "lint": "oxlint src",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "github",
    "activity",
    "gif",
    "readme"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "lefthook": "^2.1.3",
    "oxlint": "^1.48.0"
  }
}
